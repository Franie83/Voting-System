# ICAN Electronic Voting System - Environment Configuration

# Flask
FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=False

# Database
DATABASE_URL=postgresql://ican_user:ican_password@db:5432/ican_voting
SQLALCHEMY_TRACK_MODIFICATIONS=False

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=86400

# Mail
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=ICAN Elections <elections@ican.org.ng>

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key-here!!

# File Upload
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=png,jpg,jpeg,pdf,mp4

# Rate Limiting
RATELIMIT_STORAGE_URI=redis://redis:6379/1

# Sentry
SENTRY_DSN=your-sentry-dsn

# ICAN Config
ICAN_ORG_NAME="Institute of Chartered Accountants of Nigeria"
ICAN_LOGO_URL=/static/ican-logo.png
ELECTION_TIMEZONE=Africa/Lagos
